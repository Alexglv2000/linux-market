# Linux-Market POS - Configuración de Ejemplo
# Copia este archivo a .env.local para desarrollo

# Nombre de la aplicación
NEXT_PUBLIC_APP_NAME=Linux-Market

# URL base (cambia en producción)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Versión del sistema
NEXT_PUBLIC_APP_VERSION=1.0.0

# ===================================
# Base de Datos (Opcional - Futuro)
# ===================================
# Actualmente el sistema usa IndexedDB local
# Descomenta estas variables cuando implementes sincronización con servidor

# DATABASE_URL=postgresql://user:password@localhost:5432/linux_market
# DIRECT_URL=postgresql://user:password@localhost:5432/linux_market

# ===================================
# Autenticación (Opcional - Futuro)
# ===================================
# JWT_SECRET=tu-secreto-super-seguro-aqui-cambiar-en-produccion
# SESSION_DURATION=86400 # 24 horas en segundos

# ===================================
# APIs Externas (Opcional)
# ===================================
# PAYMENT_GATEWAY_KEY=
# RECEIPT_PRINTER_URL=

# ===================================
# Configuración de Email (Opcional)
# ===================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-contraseña

# ===================================
# Analytics (Opcional)
# ===================================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===================================
# Modo de Desarrollo
# ===================================
# NODE_ENV=development
