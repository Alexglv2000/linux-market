# =====================================================
# Linux-Market POS — Configuración Super Admin
# Copia este archivo como .env.local y personalízalo
# NUNCA subas .env.local a tu repositorio git
# =====================================================

# Super Admin — Credenciales
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=cambia_esta_clave_por_una_muy_segura

# Super Admin — MACs permitidas (separadas por coma)
# Para obtener tu MAC en Linux: ip link show | grep ether
# Para obtener tu MAC en macOS: ifconfig | grep ether
# Para obtener tu MAC en Windows: ipconfig /all | findstr "Physical Address"
SUPERADMIN_ALLOWED_MACS=AA:BB:CC:DD:EE:FF,11:22:33:44:55:66

# Secreto de sesión (genera uno aleatorio y seguro)
SUPERADMIN_SESSION_SECRET=genera_una_cadena_aleatoria_de_64_caracteres_aqui

# =====================================================
# Pagos — Configuración (se puede sobrescribir desde la UI)
# =====================================================
# CLABE interbancaria por defecto (18 dígitos)
DEFAULT_CLABE=000000000000000000
# Nombre del beneficiario
DEFAULT_PAYMENT_BENEFICIARY=Nombre del Negocio
